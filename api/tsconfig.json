{
  "extends": "../tsconfig.json",
  "include": ["./**/*"],
  "exclude": ["../node_modules", "../dist"],
  "compilerOptions": {
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "outDir": "../dist/api",
    "types": ["node"],
    "moduleResolution": "node",
    "noImplicitAny": false,
    "target": "ES2022",
    "module": "ES2022",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  }
}
